# =====================================================================
# Backend / Worker Configuration
# =====================================================================
# DATABASE_URL: Postgres Connection string. 
# For local dev using docker-compose: postgresql+asyncpg://user:password@127.0.0.1:5434/queueforge
# For Railway production: postgresql+asyncpg://<username>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://user:password@127.0.0.1:5434/queueforge

# REDIS_URL: Redis Connection string.
# For local dev using docker-compose: redis://127.0.0.1:6379/0
# For Railway production: redis://default:<password>@<host>:<port>
REDIS_URL=redis://127.0.0.1:6379/0

# JWT_SECRET: Secret used for signing auth tokens
# Must be generated securely for production!
JWT_SECRET=supersecretjwtkey_change_in_production

# FRONTEND_URL: Used by API for CORS validation
# For local dev: http://localhost:3000
# For Railway production: https://your-vercel-domain.vercel.app
FRONTEND_URL=http://localhost:3000

# =====================================================================
# Frontend Configuration
# =====================================================================
# NEXT_PUBLIC_API_URL: (Vercel Only) Target URL for the API proxy rewrite.
# For local dev, this isn't strictly required as it defaults to localhost:8001.
# For Vercel production: https://<your-railway-api-domain>/api/v1
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001/api/v1

# PORT: Port for the frontend application
PORT=3000
